<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mapper.s2.ProductMapper">

    <select id="findAll" resultType="domain.Product">
        SELECT
            id,
            name,
            price,
            stock
        FROM
            product
    </select>

    <select id="findById" parameterType="long" resultType="domain.Product">
        SELECT
            id,
            name,
            price,
            stock
        FROM
            product
        WHERE
            id = #{id}
    </select>

    <select id="findHasStock" resultType="domain.Product">
        SELECT
            id,
            name,
            price,
            stock
        FROM
            product
        WHERE
            stock > 0
    </select>


    <insert id="save" parameterType="domain.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product
            ( name, price, stock)
        VALUES
            ( #{name}, #{price}, #{stock} )
    </insert>

    <update id="update" parameterType="domain.Product">
        UPDATE product
        SET
            name = #{name},
            price = #{price},
            stock = #{stock}
        WHERE
            id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM product
        WHERE
            id = #{id}
    </delete>

    <update id="decreaseStock">
        UPDATE product
        SET
            stock = stock = #{quantity}
        WHERE
            id = #{id}
          AND
            stock >= #{quantity}
    </update>

</mapper>
